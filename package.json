{
  "name": "descope",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prepare": "husky install",
    "build": "nx affected --base=origin/main --target build",
    "lint": "nx affected --base=origin/main --target lint",
    "test": "nx affected --base=origin/main --target test",
    "affected:latest-tag": "nx affected --base=$(git for-each-ref --sort=creatordate --format '%(refname) %(creatordate)' refs/tags | tail -n 1 | awk '{sub(\"^refs/tags/\",\"\",$1); print $1}')",
    "version:latest-tag": "pnpm affected:latest-tag --target version --parallel 1",
    "lint:latest-tag": "pnpm affected:latest-tag --target lint",
    "print:latest-tag": "nx print-affected --base=$(git for-each-ref --sort=creatordate --format '%(refname) %(creatordate)' refs/tags | tail -n 1 | awk '{sub(\"^refs/tags/\",\"\",$1); print $1}') --select=projects"
  },
  "private": true,
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.0.0",
    "@commitlint/config-conventional": "^17.0.0",
    "@descope/core2": "^0.0.6",
    "@jscutlery/semver": "^2.30.1",
    "@nrwl/devkit": "^15.8.5",
    "@nrwl/eslint-plugin-nx": "15.7.2",
    "@nrwl/jest": "15.7.2",
    "@nrwl/js": "15.7.2",
    "@nrwl/linter": "15.7.2",
    "@nrwl/workspace": "15.7.2",
    "@types/jest": "28.1.1",
    "@types/node": "16.11.7",
    "@typescript-eslint/eslint-plugin": "^5.36.1",
    "@typescript-eslint/parser": "^5.36.1",
    "eslint": "~8.15.0",
    "eslint-config-prettier": "8.1.0",
    "husky": "^8.0.0",
    "jest": "28.1.1",
    "jest-environment-jsdom": "28.1.1",
    "ngx-deploy-npm": "^5.2.0",
    "nx": "15.7.2",
    "prettier": "^2.6.2",
    "ts-jest": "28.0.5",
    "ts-node": "10.9.1",
    "typescript": "~4.8.2"
  }
}
