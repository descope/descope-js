{
  "name": "descope",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prepare": "husky install",
    "build": "nx affected --base=origin/nx --target build",
    "lint": "nx affected --base=origin/nx --target lint",
    "test": "nx affected --base=origin/nx --target test",
    "print-affected": "nx print-affected --base=origin/nx --select=projects",
    "affected:ci": "nx affected --base=$(output=$(git ls-remote --tags --sort=\"committerdate\" origin | tail -n 1 | sed 's~.*refs/tags/~~' | sed 's/\\^{}//'); if [[ \"$output\" -gt 0 ]]; then echo $output; else echo 'origin/nx'; fi;)",
    "version:ci": "pnpm affected:ci --target version --parallel 1",
    "postversion:ci": "pnpm affected:ci --target build --parallel 1",
    "lint:ci": "pnpm affected:ci --target lint",
    "print-affected:ci": "nx print-affected --base=$(output=$(git ls-remote --tags --sort=\"committerdate\" origin | tail -n 1 | sed 's~.*refs/tags/~~' | sed 's/\\^{}//'); if [[ \"$output\" -gt 0 ]]; then echo $output; else echo 'origin/nx'; fi;) --select=projects"
  },
  "private": true,
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.0.0",
    "@commitlint/config-conventional": "^17.0.0",
    "@jscutlery/semver": "^2.30.1",
    "@nrwl/devkit": "^15.8.5",
    "@nrwl/eslint-plugin-nx": "15.7.2",
    "@nrwl/jest": "15.7.2",
    "@nrwl/js": "15.7.2",
    "@nrwl/linter": "15.7.2",
    "@nrwl/workspace": "15.7.2",
    "@types/jest": "28.1.1",
    "@types/node": "16.11.7",
    "@typescript-eslint/eslint-plugin": "^5.36.1",
    "@typescript-eslint/parser": "^5.36.1",
    "eslint": "~8.15.0",
    "eslint-config-prettier": "8.1.0",
    "husky": "^8.0.0",
    "jest": "28.1.1",
    "jest-environment-jsdom": "28.1.1",
    "ngx-deploy-npm": "^5.2.0",
    "nx": "15.7.2",
    "prettier": "^2.6.2",
    "ts-jest": "28.0.5",
    "ts-node": "10.9.1",
    "typescript": "~4.8.2"
  }
}
